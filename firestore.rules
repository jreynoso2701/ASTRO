rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuarios ──
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Empresas ──
    match /Empresas/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Proyectos ──
    match /Proyectos/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Asignaciones de proyecto ──
    match /projectAssignments/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Módulos + sub-colección Funcionalidades ──
    match /Modulos/{moduleId} {
      allow read, write: if request.auth != null;

      match /Funcionalidades/{funcId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Incidentes (Tickets) ──
    match /Incidentes/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Comentarios de Tickets + sub-colección subComentarios ──
    match /Comentarios/{document} {
      allow read, write: if request.auth != null;

      match /subComentarios/{subDoc} {
        allow read, write: if request.auth != null;
      }
    }

    // Collection group query para subComentarios
    match /{path=**}/subComentarios/{document} {
      allow read: if request.auth != null;
    }

    // ── Requerimientos ──
    match /Requerimientos/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Comentarios de Requerimientos ──
    match /ComentariosRequerimientos/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Tareas ──
    match /Tareas/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Citas ──
    match /Citas/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Comentarios de Citas ──
    match /ComentariosCitas/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Minutas ──
    match /Minutas/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Avisos ──
    match /Avisos/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Notificaciones in-app ──
    match /Notificaciones/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Configuración de notificaciones ──
    match /NotificationConfig/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Documentación ──
    match /DocumentosProyecto/{document} {
      allow read, write: if request.auth != null;
    }

    match /BitacoraDocumentos/{document} {
      allow read, write: if request.auth != null;
    }

    match /CategoriasDocumento/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Chat AI ──
    match /chatAI/{document} {
      allow read, write: if request.auth != null;

      match /mensaje/{msgDoc} {
        allow read, write: if request.auth != null;
      }
    }

    // Collection group query para mensajes AI
    match /{path=**}/mensaje/{document} {
      allow read: if request.auth != null;
    }

    // ── Catálogos ──
    match /Cobertura/{document} {
      allow read, write: if request.auth != null;
    }

    match /Prioridad/{document} {
      allow read, write: if request.auth != null;
    }

    match /Estatus/{document} {
      allow read, write: if request.auth != null;
    }

    // ── Colecciones legacy (FlutterFlow / V1) ──
    match /NotificacionesGral/{document} {
      allow read, write: if request.auth != null;
    }

    match /notIncidente/{document} {
      allow read, write: if request.auth != null;
    }

    match /Seguimiento/{document} {
      allow read, write: if request.auth != null;
    }

    match /chats/{document} {
      allow read, write: if request.auth != null;
    }

    match /chat_messages/{document} {
      allow read, write: if request.auth != null;
    }

    match /User/{document} {
      allow read, write: if request.auth != null;
    }

    match /ff_user_push_notifications/{document} {
      allow create: if request.auth != null
        && /databases/$(database)/documents/users/$(request.auth.uid) == request.resource.data.sender;
      allow read, write, delete: if false;
    }

    // ── Etiquetas ──
    match /Etiquetas/{etiquetaId} {
      // Cualquier usuario autenticado puede leer etiquetas.
      allow read: if request.auth != null;

      // Crear etiqueta global: solo Root.
      // Crear etiqueta de proyecto: Root, Lider Proyecto o Soporte.
      allow create: if request.auth != null
        && (
          // Global: solo Root
          (request.resource.data.esGlobal == true
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'root')
          ||
          // Por proyecto: Root, Lider o Soporte del proyecto
          (request.resource.data.esGlobal == false
            && (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'root'
              || exists(/databases/$(database)/documents/user_assignments/$(request.auth.uid + '_' + request.resource.data.projectId))
            ))
        );

      // Actualizar/desactivar: el creador o un Root.
      allow update, delete: if request.auth != null
        && (
          request.auth.uid == resource.data.createdByUid
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'root'
        );
    }

    // ── DENY por defecto ──
    // NO hay regla catch-all. Cualquier colección no listada
    // queda denegada automáticamente por Firestore.
  }
}
